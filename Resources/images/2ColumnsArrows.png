<script>
var dm_account_locale = 1;

function changeLanguage(langCode) {
	var index = window.location.href.indexOf("?lang=");
	var url =  window.location.href;
	
	if(index != -1) {
		url = url.substr(0, index);
	}
	
	url += ("?lang=" + langCode);
	window.location.href = url;
}
</script>

