<script>
	var moduleName = 'login';
</script>
<script>
    window.addEventListener("load", function() {
        window.$.modulesManager.getModuleAsync("login")
            .then(function (module) {
                return module.getLoginService();
            })
            .then(function (loginService) {
                var container = document.createElement('div');
                container.style.width="100%";
                var signupBox = document.getElementsByClassName('lgForm');
                if (signupBox) {
                    var parent = signupBox[0].parentNode;
                    parent.replaceChild(container, signupBox[0]);
                    if(true) {
                        loginService.getLoginScreen({
                            element: container,
                            lang: "en",
                            captcha: true ? {
                                siteKey: "6Ld3f6EnAAAAAHl9YzkhxOwfq6NzuuEfXpyazpf5",
                            } : null,
                            isWLReseller: false,
                            nonGoogleSso: false,
                            oauthSsoClientName: ""
                        })
                    } else {
                        loginService.getLoginPage({
                            element: container,
                            lang: "en",
                            captcha: true ? {
                                siteKey: "6Ld3f6EnAAAAAHl9YzkhxOwfq6NzuuEfXpyazpf5",
                            } : null,
                            isWLReseller: false
                        })
                    }
                }
            });
    }, false);
</script>

