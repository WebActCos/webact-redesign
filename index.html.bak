<script id="webact-promodo-header-script">
(function(){
  document.querySelectorAll('[data-webact-promodo-header]').forEach(function(header){
    var toggle=header.querySelector('[data-webact-menu-toggle]');
    if(toggle){toggle.addEventListener('click',function(){var open=header.classList.toggle('webact-nav-open');toggle.setAttribute('aria-expanded',open?'true':'false');});}
    header.querySelectorAll('[data-webact-dropdown]').forEach(function(btn){
      btn.addEventListener('click',function(e){
        if(window.matchMedia('(max-width:1060px)').matches){
          e.preventDefault();
          var item=btn.closest('.webact-promodo-nav-item');
          if(item){item.classList.toggle('webact-open');btn.setAttribute('aria-expanded',item.classList.contains('webact-open')?'true':'false');}
        }
      });
    });
    var search=header.querySelector('[data-webact-search-open]');
    var close=header.querySelector('[data-webact-search-close]');
    if(search){search.addEventListener('click',function(){document.body.classList.add('webact-search-open');var input=header.querySelector('.webact-search-row input');if(input){setTimeout(function(){input.focus();},50);}});}
    if(close){close.addEventListener('click',function(){document.body.classList.remove('webact-search-open');});}
  });
  document.addEventListener('keydown',function(e){if(e.key==='Escape'){document.body.classList.remove('webact-search-open');}});
})();
</script>

<script src="js/webact-promodo-nav.js" defer></script>
</body>
