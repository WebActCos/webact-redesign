{
  "baseUrl": "https://www.webact.com",
  "failOn": [
    "critical",
    "high"
  ],
  "excludeDirectories": [
    ".git",
    "node_modules",
    "vendor",
    "dist",
    "build",
    "coverage",
    ".next",
    ".cache",
    "tools",
    "pages",
    "includes",
    "assets/includes",
    "assets/templates",
    "tools/backups"
  ],
  "excludeFilePatterns": [
    "before-",
    ".before-",
    "baseline",
    "backup",
    "homepage-baseline",
    "report.html",
    "index-before-"
  ],
  "siteAreas": [
    {
      "name": "website",
      "patterns": [
        "^index\\.html$",
        "^about/(?!portfolio/|website-knowledge-base/|blog/).*",
        "^contact/",
        "^design/",
        "^digital-ads/",
        "^marketing/",
        "^pricing/",
        "^addons/(?!website-app-store/).*",
        "^(privacy|terms)(?:/|\\.html)"
      ],
      "checks": {
        "links": true,
        "assets": true,
        "seo": true,
        "canonical": true,
        "headings": true,
        "sharedLayout": true,
        "imageDimensions": true,
        "orphan": false
      }
    },
    {
      "name": "industries",
      "patterns": [
        "^industries/"
      ],
      "checks": {
        "links": true,
        "assets": true,
        "seo": true,
        "canonical": true,
        "headings": true,
        "sharedLayout": true,
        "imageDimensions": true,
        "orphan": false,
        "templateIssueAggregation": true
      }
    },
    {
      "name": "portfolio",
      "patterns": [
        "^about/portfolio/"
      ],
      "checks": {
        "links": true,
        "assets": true,
        "seo": true,
        "canonical": true,
        "headings": true,
        "sharedLayout": true,
        "imageDimensions": false,
        "orphan": false,
        "dynamicRoutes": true,
        "templateIssueAggregation": true
      }
    },
    {
      "name": "knowledge-base",
      "patterns": [
        "^about/website-knowledge-base/"
      ],
      "checks": {
        "links": true,
        "assets": true,
        "seo": false,
        "canonical": true,
        "headings": true,
        "sharedLayout": true,
        "imageDimensions": false,
        "orphan": false,
        "templateIssueAggregation": true
      }
    },
    {
      "name": "app-store",
      "patterns": [
        "^addons/website-app-store/"
      ],
      "checks": {
        "links": true,
        "assets": true,
        "seo": false,
        "canonical": true,
        "headings": true,
        "sharedLayout": true,
        "imageDimensions": false,
        "orphan": false,
        "templateIssueAggregation": true
      }
    },
    {
      "name": "blog",
      "patterns": [
        "^about/blog(?:\\.html|/)"
      ],
      "checks": {
        "links": true,
        "assets": true,
        "seo": true,
        "canonical": true,
        "headings": true,
        "sharedLayout": true,
        "imageDimensions": false,
        "orphan": false,
        "templateIssueAggregation": true
      }
    }
  ],
  "dynamicRoutePatterns": [
    "case-study\\.html\\?project=",
    "\\?project=",
    "\\$\\{[^}]+\\}",
    "\\+\\s*[A-Za-z_$][\\w$]*(?:\\[[^\\]]+\\])?\\s*\\+"
  ],
  "knownSharedSignals": {
    "header": [
      "<header",
      "site-header",
      "shared-header",
      "header-placeholder",
      "data-shared-header"
    ],
    "footer": [
      "<footer",
      "site-footer",
      "shared-footer",
      "footer-placeholder",
      "data-shared-footer"
    ]
  },
  "templateMarkers": {
    "industries": [
      "Parking & Mobility Website Design | WebAct",
      "Parking &amp; Mobility Website Design | WebAct"
    ],
    "portfolio": [
      "Parking & Mobility Case Study | WebAct",
      "Parking &amp; Mobility Case Study | WebAct"
    ]
  },
  "collectionRules": {
    "website": {
      "maxDuplicateGroup": 3
    },
    "industries": {
      "maxDuplicateGroup": 2
    },
    "portfolio": {
      "maxDuplicateGroup": 2
    },
    "knowledge-base": {
      "maxDuplicateGroup": 3
    },
    "app-store": {
      "maxDuplicateGroup": 3
    },
    "blog": {
      "maxDuplicateGroup": 3
    }
  },
  "severity": {
    "brokenInternalLink": "critical",
    "missingAsset": "critical",
    "missingCanonical": "medium",
    "missingTitle": "high",
    "missingDescription": "medium",
    "missingH1": "high",
    "multipleH1": "medium",
    "missingHeader": "medium",
    "missingFooter": "medium",
    "duplicateTitle": "medium",
    "duplicateDescription": "low",
    "templateNotReplaced": "high",
    "imageDimensions": "info",
    "missingRobots": "medium",
    "missingSitemap": "high"
  }
}